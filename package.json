{
  "name": "ai-auction-property-analyzer",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "seed:admin": "npm run seed:admin -w backend",
    "migrate": "npm run migrate -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

